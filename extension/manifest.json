{
  "manifest_version": 2,
  "name": "Native English Refiner",
  "version": "1.0.0",
  "description": "Refine selected text into natural native English",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.upwork.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Native English Refiner"
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
